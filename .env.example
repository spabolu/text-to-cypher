# Copy to .env locally and replace placeholders with real values.
# Do not commit your real .env file.

NEO4J_URI=neo4j+s://YOUR_AURA_INSTANCE.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=YOUR_NEO4J_PASSWORD
NEO4J_DATABASE=neo4j
AURA_INSTANCEID=YOUR_AURA_INSTANCE_ID
AURA_INSTANCENAME=YOUR_AURA_INSTANCE_NAME

# Optional notebook/runtime settings
WAIT_SECONDS=60
